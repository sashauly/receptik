    "prettier:format": "prettier --write .",
    "ts:check": "tsc --noEmit",
    "generate-pwa-assets": "pwa-assets-generator",
    "interface": "i18next-resources-for-ts interface -i ./public/locales/en -o ./src/types/resources.d.ts"
